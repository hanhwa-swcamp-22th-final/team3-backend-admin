<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ohgiraffers.team3backendadmin.admin.query.mapper.EmployeeMapper">

    <resultMap id="employeeResultMap"
               type="com.ohgiraffers.team3backendadmin.admin.query.dto.response.employee.EmployeeResponse">
        <result property="employeeId" column="employee_id"/>
        <result property="employeeCode" column="employee_code"/>
        <result property="employeeName" column="employee_name"/>
        <result property="employeeEmail" column="employee_email"/>
        <result property="employeePhone" column="employee_phone"/>
        <result property="employeeAddress" column="employee_address"/>
        <result property="employeeEmergencyContact" column="employee_emergency_contact"/>
        <result property="employeeRole" column="employee_role"/>
        <result property="employeeStatus" column="employee_status"/>
        <result property="employeeTier" column="employee_tier"/>
        <result property="hireDate" column="hire_date"/>
    </resultMap>

    <select id="findByEmployeeCode" resultMap="employeeResultMap">
        SELECT employee_id,
               employee_code,
               employee_name,
               employee_email,
               employee_phone,
               employee_address,
               employee_emergency_contact,
               employee_role,
               employee_status,
               employee_tier,
               hire_date
          FROM employee
         WHERE employee_code = #{employeeCode}
    </select>

    <select id="findAll" resultMap="employeeResultMap">
        SELECT employee_id,
               employee_code,
               employee_name,
               employee_email,
               employee_phone,
               employee_address,
               employee_emergency_contact,
               employee_role,
               employee_status,
               employee_tier,
               hire_date
          FROM employee
         ORDER BY employee_id
    </select>

    <resultMap id="employeeSummaryResultMap"
               type="com.ohgiraffers.team3backendadmin.admin.query.dto.response.employee.EmployeeSummaryResponse">
        <result property="employeeName" column="employee_name"/>
        <result property="employeeCode" column="employee_code"/>
        <result property="employeeRole" column="employee_role"/>
        <result property="employeeStatus" column="employee_status"/>
        <result property="employeeTier" column="employee_tier"/>
        <result property="hireDate" column="hire_date"/>
        <result property="factoryLineName" column="factory_line_name"/>
        <result property="equipmentName" column="equipment_name"/>
    </resultMap>

    <select id="findAllSummary" resultMap="employeeSummaryResultMap">
        SELECT e.employee_name,
               e.employee_code,
               e.employee_role,
               e.employee_status,
               e.employee_tier,
               e.hire_date,
               fl.factory_line_name,
               eq.equipment_name
          FROM employee e
          LEFT JOIN worker_deployment wd ON e.employee_id = wd.employee_id
          LEFT JOIN equipment eq ON wd.equipment_id = eq.equipment_id
          LEFT JOIN equipment_process ep ON eq.equipment_process_id = ep.equipment_process_id
          LEFT JOIN factory_line fl ON ep.factory_line_id = fl.factory_line_id
         ORDER BY e.employee_id
    </select>

    <resultMap id="employeeProfileResultMap"
               type="com.ohgiraffers.team3backendadmin.admin.query.dto.response.employee.EmployeeProfileQueryResponse">
        <result property="employeeId" column="employee_id"/>
        <result property="employeeCode" column="employee_code"/>
        <result property="employeeName" column="employee_name"/>
        <result property="departmentName" column="department_name"/>
        <result property="teamName" column="team_name"/>
        <result property="currentTier" column="current_tier"/>
        <result property="totalScore" column="total_score"/>
        <result property="hireDate" column="hire_date"/>
    </resultMap>

    <select id="findProfileByEmployeeId" resultMap="employeeProfileResultMap">
        SELECT e.employee_id,
               e.employee_code,
               e.employee_name,
               e.hire_date,
               COALESCE(pd.department_name, d.department_name) AS department_name,
               d.team_name,
               e.employee_tier AS current_tier,
               CAST(ls.total_points AS DECIMAL(10, 2)) AS total_score
          FROM employee e
          LEFT JOIN department d
            ON e.department_id = d.department_id
          LEFT JOIN department pd
            ON d.parent_department_id = pd.department_id
          LEFT JOIN (
                SELECT s1.employee_id,
                       s1.total_points
                  FROM score s1
                  JOIN (
                        SELECT employee_id, MAX(eval_period_id) AS max_eval_period_id
                          FROM score
                         GROUP BY employee_id
                  ) latest
                    ON latest.employee_id = s1.employee_id
                   AND latest.max_eval_period_id = s1.eval_period_id
          ) ls
            ON ls.employee_id = e.employee_id
         WHERE e.employee_id = #{employeeId}
    </select>

    <resultMap id="employeeSkillResultMap"
               type="com.ohgiraffers.team3backendadmin.admin.query.dto.response.employee.EmployeeSkillQueryResponse">
        <result property="skillId" column="skill_id"/>
        <result property="skillName" column="skill_name"/>
        <result property="skillScore" column="skill_score"/>
    </resultMap>

    <select id="findSkillsByEmployeeId" resultMap="employeeSkillResultMap">
        SELECT skill_id,
               skill_category AS skill_name,
               skill_score
          FROM skill
         WHERE employee_id = #{employeeId}
         ORDER BY skill_category
    </select>

    <resultMap id="tierChartPointResultMap"
               type="com.ohgiraffers.team3backendadmin.admin.query.dto.response.employee.TierChartPointQueryResponse">
        <result property="year" column="year"/>
        <result property="evalSequence" column="eval_sequence"/>
        <result property="tier" column="tier"/>
        <result property="totalScore" column="total_score"/>
    </resultMap>

    <select id="findTierChartByEmployeeId" resultMap="tierChartPointResultMap">
        SELECT ep.eval_year AS year,
               ep.eval_sequence,
               s.tier,
               CAST(s.total_points AS DECIMAL(10, 2)) AS total_score
          FROM score s
          JOIN evaluation_period ep
            ON ep.eval_period_id = s.eval_period_id
         WHERE s.employee_id = #{employeeId}
         ORDER BY ep.eval_year, ep.eval_sequence
    </select>

</mapper>
