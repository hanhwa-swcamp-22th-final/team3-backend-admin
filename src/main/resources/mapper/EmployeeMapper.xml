<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ohgiraffers.team3backendadmin.admin.query.mapper.EmployeeMapper">

    <resultMap id="employeeResultMap"
               type="com.ohgiraffers.team3backendadmin.admin.query.dto.response.EmployeeResponse">
        <result property="employeeId" column="employee_id"/>
        <result property="employeeCode" column="employee_code"/>
        <result property="employeeName" column="employee_name"/>
        <result property="employeeEmail" column="employee_email"/>
        <result property="employeePhone" column="employee_phone"/>
        <result property="employeeAddress" column="employee_address"/>
        <result property="employeeEmergencyContact" column="employee_emergency_contact"/>
        <result property="employeeRole" column="employee_role"/>
        <result property="employeeStatus" column="employee_status"/>
        <result property="employeeTier" column="employee_tier"/>
    </resultMap>

    <select id="findByEmployeeCode" resultMap="employeeResultMap">
        SELECT employee_id,
               employee_code,
               employee_name,
               employee_email,
               employee_phone,
               employee_address,
               employee_emergency_contact,
               employee_role,
               employee_status,
               employee_tier
          FROM employee
         WHERE employee_code = #{employeeCode}
    </select>

    <select id="findAll" resultMap="employeeResultMap">
        SELECT employee_id,
               employee_code,
               employee_name,
               employee_email,
               employee_phone,
               employee_address,
               employee_emergency_contact,
               employee_role,
               employee_status,
               employee_tier
          FROM employee
         ORDER BY employee_id
    </select>

</mapper>