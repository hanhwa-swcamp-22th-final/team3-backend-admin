### 로그인 (accessToken 획득)
POST http://localhost:8080/api/v1/auth/login
Content-Type: application/json

{
  "employeeEmail": "sinseon2000@company.com",
  "password": "password123!"
}

> {%
    client.global.set("accessToken", response.body.data.accessToken);
    client.global.set("refreshToken", response.body.data.refreshToken);
%}

### 사원 등록
POST http://localhost:8080/api/v1/organization/employee
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "departmentId": 1774590584056408,
  "employeeName": "고길동",
  "employeeEmail": "sample990@company.com",
  "employeePhone": "010-5541-0981",
  "employeeAddress": "서울시 강남구 테헤란로 7189",
  "employeeEmergencyContact": "010-7664-9364",
  "employeePassword": "password123!",
  "employeeRole": "DL",
  "employeeStatus": "ACTIVE",
  "employeeTier": "S"
}

### 사원 등록 실패 - 필수 항목 누락 (400 Bad Request)
POST http://localhost:8080/api/v1/organization/employee
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "departmentId": 1000000000000002,
  "employeeName": "",
  "employeeEmail": "hong@company.com",
  "employeePhone": "010-1234-5678",
  "employeeAddress": "서울시 강남구",
  "employeeEmergencyContact": "010-9876-5432",
  "employeePassword": "password123!",
  "employeeRole": "WORKER",
  "employeeStatus": "ACTIVE",
  "employeeTier": "B"
}

### 선택 사원 조회
GET http://localhost:8080/api/v1/organization/employee/EMP2603002
Authorization: Bearer {{accessToken}}

### 전체 사원 조회
GET http://localhost:8080/api/v1/organization/employees
Authorization: Bearer {{accessToken}}

### 사원 스킬 점수 수정 - 전체 카테고리
PUT http://localhost:8080/api/v1/organization/employee/skill
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "employeeCode": "EMP2603003",
  "equipmentResponse": 85.50,
  "technicalTransfer": 90.00,
  "innovationProposal": 75.25,
  "safetyCompliance": 88.00,
  "qualityManagement": 92.50,
  "productivity": 80.00
}

### 사원 스킬 점수 수정 - 일부 카테고리만
PUT http://localhost:8080/api/v1/organization/employee/skill
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "employeeCode": "EMP2603003",
  "equipmentResponse": 95.00,
  "technicalTransfer": null,
  "innovationProposal": null,
  "safetyCompliance": null,
  "qualityManagement": null,
  "productivity": 88.50
}

### 사원 역할 변경 - 사유 및 적용일 포함
PUT http://localhost:8080/api/v1/organization/employee/role
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "employeeCode": "EMP2603004",
  "newRole": "TL",
  "reason": "팀장 승진",
  "effectiveDate": "2026-04-01T00:00:00"
}

### 사원 역할 변경 - 사유 없이
PUT http://localhost:8080/api/v1/organization/employee/role
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "employeeCode": "EMP2603004",
  "newRole": "DL",
  "reason": null,
  "effectiveDate": "2026-05-01T00:00:00"
}

### 사원 삭제 (Soft Delete - 상태 변경)
DELETE http://localhost:8080/api/v1/organization/employee/EMP2603001
Authorization: Bearer {{accessToken}}

