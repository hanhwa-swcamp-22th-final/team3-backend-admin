### 로그인 후 accessToken 발급
POST http://localhost:8080/api/v1/auth/login
Content-Type: application/json

{
  "employeeEmail": "masterAdmin@company.com",
  "password": "password123!"
}

> {%
    client.global.set("refreshToken", response.body.data.refreshToken);
    client.global.set("accessToken", response.body.data.accessToken);
%}

### 설비 생성
POST http://localhost:8080/api/v1/equipment-management/equipments
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "equipmentProcessId": 2001,
  "environmentStandardId": 3001,
  "equipmentCode": "EQ-API-001",
  "equipmentName": "API Printing Equipment",
  "equipmentStatus": "OPERATING",
  "equipmentGrade": "A",
  "equipmentDescription": "API created equipment",
  "equipmentWarrantyMonth": 24,
  "equipmentDesignLifeMonths": 120,
  "equipmentWearCoefficient": 0.75
}

### 설비 수정
PUT http://localhost:8080/api/v1/equipment-management/equipments/4001
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "equipmentProcessId": 2001,
  "environmentStandardId": 3001,
  "equipmentCode": "EQ-API-999",
  "equipmentName": "API Updated Equipment",
  "equipmentStatus": "STOPPED",
  "equipmentGrade": "B",
  "equipmentDescription": "API updated equipment",
  "equipmentWarrantyMonth": 36,
  "equipmentDesignLifeMonths": 180,
  "equipmentWearCoefficient": 0.9
}

### 설비 삭제
DELETE http://localhost:8080/api/v1/equipment-management/equipments/4001
Authorization: Bearer {{accessToken}}

### 설비 목록 조회
GET http://localhost:8080/api/v1/equipment-management/equipments?keyword=API&equipmentStatus=OPERATING&equipmentGrade=A
Authorization: Bearer {{accessToken}}

### 설비 상세 조회
GET http://localhost:8080/api/v1/equipment-management/equipments/4001
Authorization: Bearer {{accessToken}}